@namespace Jewbox.Components

<div class="@RootClass" display="inline" @attributes="AdditionalAttributes">
    <label>Часы</label>
    <select class="form-select" style="max-width: 120px;" value="@Hour" @onchange="OnHourChanged">
        @for (var h = 8; h < 16; h++)
        {
            <option value="@h">@h.ToString("00")</option>
        }
    </select>

    <label>Минуты</label>
    <select class="form-select" style="max-width: 120px;" value="@Minute" @onchange="OnMinuteChanged">
        @for (var m = 0; m < 60; m += MinuteStep)
        {
            <option value="@m">@m.ToString("00")</option>
        }
    </select>

</div>

@code
{
    [Parameter] public TimeOnly? Value { get; set; }
    [Parameter] public EventCallback<TimeOnly?> ValueChanged { get; set; }

    [Parameter] public int MinuteStep { get; set; } = 5;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string RootClass
    {
        get
        {
            var cls = "d-flex gap-2";
            if (AdditionalAttributes is not null &&
                AdditionalAttributes.TryGetValue("class", out var c) &&
                c is not null &&
                !string.IsNullOrWhiteSpace(c.ToString()))
            {
                cls += " " + c;
            }

            return cls;
        }
    }

    private int Hour => (Value ?? new TimeOnly(9, 0)).Hour;
    private int Minute
    {
        get
        {
            var m = (Value ?? new TimeOnly(9, 0)).Minute;
            if (MinuteStep <= 1)
            {
                return m;
            }

            return (m / MinuteStep) * MinuteStep;
        }
    }

    private async Task OnHourChanged(ChangeEventArgs e)
    {
        var hour = int.TryParse(e.Value?.ToString(), out var h) ? h : 9;
        await ValueChanged.InvokeAsync(new TimeOnly(hour, Minute));
    }

    private async Task OnMinuteChanged(ChangeEventArgs e)
    {
        var minute = int.TryParse(e.Value?.ToString(), out var m) ? m : 0;
        await ValueChanged.InvokeAsync(new TimeOnly(Hour, minute));
    }
}

