@page "/"

@using Jewbox.Models
@using Jewbox.Repositories
@using Jewbox.Services

@inject IUserRepository Users
@inject IBookingService BookingService
@inject IApiSenderService ApiSenderService
@inject IJSRuntime JS


<PageTitle>Booking</PageTitle>

<div class="mb-3">
    <label class="form-label">Когда бронируем</label>
    <label class="form-label">понедельник с 12:30 до 16:00, вторник с 14:00 до 16:00, среда с 8:00 до 12:00. </label>
    
    <InputDate class="form-control" @bind-Value="SelectedDate" />
    
    <CustomTimeEdit class="mt-2" @bind-Value="SelectedTime" MinuteStep="15" />
    
    @if (ShowDateWarning)
    {
        <div class="alert alert-warning mt-2 mb-0">
            Вы выбрали некорректный день или время — проверьте доступные временные окна перед бронированием.
        </div>
    }
    
    <label class="form-label">На кого бронируем</label>
    <select class="form-select" @bind="SelectedUserId">
        @foreach (var u in AllUsers)
        {
            <option value="@u.Id">@u.Name (@u.NameCode)</option>
        }
    </select>

    @if (SelectedUser is not null)
    {
        <div class="card mt-2">
            <div class="card-body py-2">
                <div><b>Организация:</b> @SelectedUser.OrgName</div>
                <div><b>Спецучет:</b> @SelectedUser.OrgCode</div>
                <div><b>Именник:</b> @SelectedUser.NameCode</div>
                <div><b>ФИО:</b> @SelectedUser.Name</div>
                <div><b>Email:</b> @SelectedUser.Email</div>
                <div><b>Телефон:</b> @SelectedUser.Phone</div>
            </div>
        </div>
    }
</div>

<div class="d-flex gap-2">
    <button class="btn btn-primary" @onclick="SendSrochno">Забронировать срочный</button>
    <button class="btn btn-primary" @onclick="SendRegular">Забронировать несрочный, до 100</button>
</div>

@if (!string.IsNullOrWhiteSpace(Status))
{
    <div class="alert alert-info mt-3 mb-0">@Status</div>
}

@code {
    private IReadOnlyList<User> AllUsers { get; set; } = Array.Empty<User>();
    private DateTime? SelectedDateTime { get; set; } = DateTime.Today.AddMonths(1).AddDays(1).AddHours(8);
    private int SelectedUserId { get; set; }
    private string? Status { get; set; }

    private bool ShowDateWarning => !BookingService.IsCorrectDate(SelectedDateTime);
    private User? SelectedUser => AllUsers.FirstOrDefault(u => u.Id == SelectedUserId);

    private DateTime? SelectedDate
    {
        get => SelectedDateTime?.Date;
        set
        {
            var time = SelectedDateTime?.TimeOfDay ?? new TimeSpan(9, 0, 0);
            SelectedDateTime = (value ?? DateTime.Today).Date.Add(time);
        }
    }

    private TimeOnly? SelectedTime
    {
        get => SelectedDateTime is null ? null : TimeOnly.FromDateTime(SelectedDateTime.Value);
        set
        {
            var date = SelectedDateTime?.Date ?? DateTime.Today;
            SelectedDateTime = date.Add((value ?? new TimeOnly(9, 0)).ToTimeSpan());
        }
    }

    protected override void OnInitialized()
    {
        AllUsers = Users.GetUsers();
        SelectedUserId = AllUsers.FirstOrDefault()?.Id ?? 0;
    }

    private void SendSrochno()
    {
        if (Validate().Result)
        {
            Send(BookingType.proizvoditeli_sro4no);
        }
    }
    private void SendRegular()
    {
        if (Validate().Result)
        {
            Send(BookingType.proizvoditeli_do_100);
        }
    }
    
    private void Send(BookingType bookingType)
    {
        Status = null;
        if (SelectedDateTime is null)
        {
            Status = "Select a date.";
            return;
        }

        var start = SelectedDateTime.Value;
        var booking = BookingService.GetBooking(SelectedUserId, bookingType, start);
        try
        {
            var sentResult = ApiSenderService.SendRequest(booking);
            Status = sentResult switch
            {
                SentStatus.UnknownError => "Что-то пошло не так",
                SentStatus.Success => "Забронировано, проверьте почту",
                SentStatus.Test => "Тестовое бронирование завершено, отправки не было",
                SentStatus.WrongDate => "Дата не проходит. возможно наложение праздника или смена расписания",
                SentStatus.DayBusy => "Дата уже занята",
                SentStatus.CantGetSecret => "Не удалось получить секрет",
                _ => throw new ArgumentOutOfRangeException(),
            };
        }
        catch (Exception e)
        {
            Status = "ошибка отправки";
            
            Console.WriteLine(e);
            throw;
        }
    }

    private async Task<bool> Validate()
    {
        if (SelectedDateTime is null)
        {
            Status = "Select a date.";
            return false;
        }
        
        var who = SelectedUser is null ? "не выбран пользователь" : $"{SelectedUser.Name} ({SelectedUser.NameCode})";
        var when = SelectedDateTime is null ? "не выбрана дата/время" : SelectedDateTime.Value.ToString("dd.MM.yyyy HH:mm");
        //var ok = await JS.InvokeAsync<bool>("confirm", $"Создать срочную бронь?\n\nКто: {who}\nКогда: {when}");
        return true;
    }
}

